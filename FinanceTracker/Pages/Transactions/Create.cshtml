@page
@model FinanceTracker.Pages.Transactions.CreateModel
@{
    ViewData["Title"] = "Add Transaction";
}

<h1>Add Transaction</h1>

<form method="post">  // validated form field for transaction date. 
    <div class="mb-3">
        <label asp-for="Transaction.Date" class="form-label"></label>
        <input asp-for="Transaction.Date" class="form-control" />
        <span asp-validation-for="Transaction.Date" class="text-danger"></span>
    </div>

    <div class="mb-3"> // validated form field for transaction discription.
        <label asp-for="Transaction.Description" class="form-label"></label>
        <input asp-for="Transaction.Description" class="form-control" />
        <span asp-validation-for="Transaction.Description" class="text-danger"></span>
    </div>

  



</form>

